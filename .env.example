# Optional: enables GPT-generated answers instead of retrieved text only
OPENAI_API_KEY=

# Answer generation (defaults to the cheapest model; output is token-capped)
LLM_MODEL=gpt-4.1-nano
ANSWER_TEMPERATURE=0.2
ANSWER_MAX_TOKENS=512

# Browser-facing API URL (baked into the frontend image at build time)
REACT_APP_API_URL=http://localhost:8000

# Comma-separated origins allowed by the backend CORS middleware
CORS_ORIGINS=http://localhost:3000

# Embeddings (OpenAI; no local torch model). Dimension must match the
# Pinecone index — change both together and recreate the index.
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# Hybrid retrieval tuning
HYBRID_FETCH_K=10
RRF_K=60

# Upload guardrail (megabytes)
MAX_UPLOAD_MB=20

# Pinecone (dense vector store). Create a free serverless index project at
# https://www.pinecone.io/ and paste the API key. The index is auto-created
# on first upload using these settings.
PINECONE_API_KEY=pcsk_cyybM_Bno61BaaJVdaKvNu6WbtcWNBcTY5HtaCSNov9RacsZPrzvqzw6epcS9CgCE215M
PINECONE_INDEX_NAME=rag-chunks
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# Session lifecycle. Uploaded documents are stored locally only for the life
# of a session and deleted when it ends (explicit DELETE /session call) or
# after this many hours of inactivity (background sweep).
SESSION_TTL_HOURS=24
SESSION_SWEEP_INTERVAL_MINUTES=60

# Deployment (used by docker-compose.prod.yml on the server)
GHCR_OWNER=codee-geek
