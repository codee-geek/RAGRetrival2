# Optional: enables GPT-generated answers instead of retrieved text only
OPENAI_API_KEY=

# Answer generation (defaults to the cheapest model; output is token-capped)
LLM_MODEL=gpt-4.1-nano
ANSWER_TEMPERATURE=0.2
ANSWER_MAX_TOKENS=512

# Browser-facing API URL (baked into the frontend image at build time)
REACT_APP_API_URL=http://localhost:8000

# Comma-separated origins allowed by the backend CORS middleware
CORS_ORIGINS=http://localhost:3000

# Hybrid retrieval tuning
HYBRID_FETCH_K=10
RRF_K=60

# Local Qdrant (leave empty to use on-disk Qdrant without Docker)
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=rag_chunks

# AWS S3 (optional — leave empty to use local disk storage for dev)
# Free-tier notes: uploads are de-duplicated by content hash (no redundant
# PUTs / duplicate storage) and stats endpoints avoid S3 LIST calls. To cap
# storage growth, add an S3 lifecycle rule on the bucket to expire objects
# under the S3_PREFIX after N days.
S3_BUCKET_NAME=
S3_PREFIX=rag-documents
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
